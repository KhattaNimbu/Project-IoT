# ═══════════════════════════════════════════════════════════════
#  .gitignore — Smart Air Quality Monitoring System (Central)
#  Covers: Backend/, frontend/, files/
# ═══════════════════════════════════════════════════════════════

# ── SECRETS & ENVIRONMENT VARIABLES (CRITICAL) ────────────────
# These contain database credentials, API keys, passwords, etc.
# NEVER commit these — leaking them is a security incident.
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
.env*.local
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.jks

# ── DEPENDENCIES ──────────────────────────────────────────────
# Installed packages — always regenerated from package-lock.json
node_modules/
bower_components/
jspm_packages/

# ── BUILD OUTPUT ──────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
*.local

# ── LOGS ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS GENERATED FILES ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
$RECYCLE.BIN/
*.lnk

# ── EDITOR & IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── TYPESCRIPT ────────────────────────────────────────────────
*.tsbuildinfo

# ── TEST & COVERAGE ──────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── DEPLOYMENT & CI ──────────────────────────────────────────
.netlify/
.vercel/
.serverless/

# ── PACKAGE MANAGERS ─────────────────────────────────────────
# Lock files are usually committed, but pnpm lock alongside npm
# lock can cause confusion — keep only one
pnpm-lock.yaml

# ── BACKUPS & OLD VERSIONS ───────────────────────────────────
frontend-old/
*.bak
*.backup
*.tmp
*.temp

# ── MISC ─────────────────────────────────────────────────────
.config/
.cache/
.parcel-cache/
.builder/
.eslintcache
.stylelintcache

# ── ARDUINO / ESP32 BUILD ARTIFACTS ──────────────────────────
# If compiling locally, these are generated
*.elf
*.hex
*.bin
*.o
*.d
